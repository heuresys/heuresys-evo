{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Heuresys design tokens — LIGHT theme override. Only color tokens that differ from tokens-dark.json. Spacing, radius, typography, motion are theme-invariant and live in tokens-dark.json (treated as base).",
  "$metadata": {
    "version": "1.0.0",
    "phase": "11",
    "direction": "mu-architect-legacy",
    "lastUpdate": "2026-05-07",
    "extends": "tokens-dark.json",
    "scope": "color-only-overrides"
  },

  "color": {
    "brand": {
      "blue": {
        "$type": "color",
        "$value": "#2452c8",
        "$description": "Logo wordmark body — darker blue for light mode contrast."
      },
      "blueDeep": {
        "$type": "color",
        "$value": "#1e3fa0"
      },
      "purple": {
        "$type": "color",
        "$value": "#7e3fc8",
        "$description": "Wordmark 'y' accent — darker purple for light mode contrast."
      },
      "purpleDeep": {
        "$type": "color",
        "$value": "#5e2898"
      }
    },
    "accent": {
      "default": {
        "$type": "color",
        "$value": "#4954c4",
        "$description": "UI accent — darkened for light surfaces."
      },
      "hover": {
        "$type": "color",
        "$value": "#3d47b0"
      },
      "soft": {
        "$type": "color",
        "$value": "#e8eaf8"
      },
      "deep": {
        "$type": "color",
        "$value": "#2c358a"
      }
    },
    "surface": {
      "bg": {
        "$type": "color",
        "$value": "#f7f8fb",
        "$description": "Off-white cool primary background."
      },
      "1": {
        "$type": "color",
        "$value": "#ffffff"
      },
      "2": {
        "$type": "color",
        "$value": "#f0f1f6"
      },
      "3": {
        "$type": "color",
        "$value": "#e6e8f0"
      }
    },
    "ink": {
      "default": {
        "$type": "color",
        "$value": "#0a0a10"
      },
      "soft": {
        "$type": "color",
        "$value": "#2a2c34"
      },
      "muted": {
        "$type": "color",
        "$value": "#6a6c75"
      },
      "tertiary": {
        "$type": "color",
        "$value": "#9ea0a8"
      }
    },
    "rule": {
      "default": {
        "$type": "color",
        "$value": "#d8dae0"
      },
      "strong": {
        "$type": "color",
        "$value": "#b6b9c2"
      }
    },
    "logo": {
      "body": {
        "$type": "color",
        "$value": "{color.ink.default}",
        "$description": "L28 wordmark relative body inherits light ink."
      },
      "tokenLabel": {
        "$type": "color",
        "$value": "#1a8e3e"
      }
    },
    "semantic": {
      "success": {
        "$type": "color",
        "$value": "#2da147"
      },
      "warning": {
        "$type": "color",
        "$value": "#b8860b"
      },
      "danger": {
        "$type": "color",
        "$value": "#c01818"
      },
      "info": {
        "$type": "color",
        "$value": "#2452c8"
      }
    }
  },

  "glass": {
    "bg": {
      "$type": "color",
      "$value": "rgba(255, 255, 255, 0.55)"
    },
    "border": {
      "$type": "color",
      "$value": "rgba(10, 13, 24, 0.08)"
    }
  },

  "shadow": {
    "card": {
      "$type": "shadow",
      "$value": {
        "color": "rgba(0, 0, 0, 0.06)",
        "offsetX": "0px",
        "offsetY": "1px",
        "blur": "2px",
        "spread": "0px"
      }
    },
    "elevated": {
      "$type": "shadow",
      "$value": {
        "color": "rgba(0, 0, 0, 0.10)",
        "offsetX": "0px",
        "offsetY": "4px",
        "blur": "16px",
        "spread": "0px"
      }
    },
    "overlay": {
      "$type": "shadow",
      "$value": {
        "color": "rgba(0, 0, 0, 0.16)",
        "offsetX": "0px",
        "offsetY": "16px",
        "blur": "32px",
        "spread": "0px"
      }
    },
    "brandGlow": {
      "$type": "shadow",
      "$value": {
        "color": "rgba(126, 63, 200, 0.18)",
        "offsetX": "0px",
        "offsetY": "0px",
        "blur": "40px",
        "spread": "4px"
      }
    }
  }
}
