{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_": "Mutation testing scaffold (S28 Wave 2 M5). Run: npx stryker run",
  "packageManager": "npm",
  "reporters": ["clear-text", "progress"],
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.config.ts"
  },
  "mutate": ["src/auth/**/*.ts", "src/rbp/**/*.ts", "!src/**/*.test.ts", "!src/**/__tests__/**"],
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 40
  },
  "timeoutMS": 30000,
  "concurrency": 2,
  "tempDirName": ".stryker-tmp",
  "checkers": [],
  "coverageAnalysis": "perTest"
}
