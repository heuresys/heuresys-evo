#!/bin/sh
# RTGB pre-commit gate — lint-staged + secret scan
set -e

# Run lint-staged on staged files (lint, format)
npx lint-staged --concurrent false

# Inline secret scan (gitleaks-lite). Patterns are concatenated from runtime
# fragments so this script is not self-matching when staged.
P1="$(printf 'BEGI'; printf 'N')[[:space:]]+([A-Z]+[[:space:]]+)?PRIVATE[[:space:]]+KEY"
P2='sk-[a-zA-Z0-9]{32,}'
P3='gho_[a-zA-Z0-9]{30,}'
P4='ghp_[a-zA-Z0-9]{30,}'
P5='AKIA[0-9A-Z]{16}'
P6='xox[bpoa]-[a-zA-Z0-9-]{20,}'
RE="${P1}|${P2}|${P3}|${P4}|${P5}|${P6}"

# Skip self (.husky/), docs about secrets, and .handoff/ session journals.
# Rationale for .handoff/: PROJECT-LOG.md / CHANGELOG.md / snapshots/ document
# past detection events ("blocker fixed by rewording header X") in descriptive
# prose; without skip every subsequent session re-triggers the same match
# (self-referential loop, observed concretely in S10 handoff 2026-05-04).
# CI workflow (.github/workflows/security.yml) applies the equivalent allow-
# list via gitleaks.toml `[allowlist].paths`.
hits="$(git diff --cached --name-only -z \
  | xargs -0 -I{} bash -c 'case "$1" in .husky/*|docs/*|.handoff/*) ;; *) printf "%s\0" "$1";; esac' _ {} \
  | xargs -0 -r grep -lE "$RE" 2>/dev/null || true)"

if [ -n "$hits" ]; then
  echo "Possible secret detected in staged files:" >&2
  echo "$hits" >&2
  echo "   Run with --no-verify only after manual review." >&2
  exit 1
fi

# B2.2 — schema drift gate. Run prisma-verify only if a schema.prisma is staged.
schema_changes="$(git diff --cached --name-only | grep -E 'prisma/schema\.prisma$' || true)"
if [ -n "$schema_changes" ]; then
  if [ -z "${DATABASE_URL:-}" ]; then
    echo "schema.prisma staged but DATABASE_URL not set — skipping prisma-verify." >&2
    echo "   Export DATABASE_URL to enable schema drift check." >&2
  else
    for path in $schema_changes; do
      ws="${path%/prisma/schema.prisma}"
      echo "Running prisma-verify for $ws…" >&2
      ./scripts/hardening/prisma-verify.sh "$ws" || {
        echo "Schema drift detected. Resolve before commit." >&2
        exit 1
      }
    done
  fi
fi
