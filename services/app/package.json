{
  "name": "@heuresys/app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Heuresys SaaS dashboard (services/app) â€” Next.js 16 + NextAuth v5",
  "scripts": {
    "dev": "next dev --port 3200",
    "build": "NODE_OPTIONS='--max-old-space-size=4096' next build && cp -r public .next/standalone/services/app/ 2>/dev/null; mkdir -p .next/standalone/services/app/.next && cp -r .next/static .next/standalone/services/app/.next/ 2>/dev/null; true",
    "analyze": "NODE_OPTIONS='--max-old-space-size=4096' next experimental-analyze -o",
    "start": "next start --port 3200",
    "lint": "echo '@heuresys/app: lint via tsc only (next lint deprecato in Next.js 16, ESLint flat config TBD)' && exit 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prisma:pull": "prisma db pull --schema prisma/schema.prisma",
    "prisma:prune": "bash scripts/prune-prisma-schema.sh",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:refresh": "npm run prisma:pull && npm run prisma:prune && npm run prisma:generate",
    "clean": "rimraf .next out node_modules/.cache",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@heuresys/shared": "*",
    "@heuresys/ui": "*",
    "@prisma/client": "^5.22.0",
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "^3.0.3",
    "next": "^16.2.4",
    "next-auth": "^4.24.14",
    "next-themes": "^0.4.6",
    "openai": "^4.104.0",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-grid-layout": "^2.2.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@next/bundle-analyzer": "^16.2.6",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "3.0.0",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "25.9.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-grid-layout": "^2.1.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.0",
    "autocannon": "^8.0.0",
    "eslint": "10.4.1",
    "eslint-config-next": "16.2.4",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.1.1",
    "postcss": "8.5.14",
    "prisma": "5.22.0",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
