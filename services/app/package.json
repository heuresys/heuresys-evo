{
  "name": "@heuresys/app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Heuresys SaaS dashboard (services/app) — Next.js 16 + NextAuth v5",
  "scripts": {
    "dev": "next dev --port 3200",
    "build": "next build",
    "start": "next start --port 3200",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prisma:pull": "prisma db pull --schema prisma/schema.prisma",
    "prisma:prune": "bash scripts/prune-prisma-schema.sh",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:refresh": "npm run prisma:pull && npm run prisma:prune && npm run prisma:generate",
    "clean": "rimraf .next out node_modules/.cache"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@heuresys/shared": "*",
    "@heuresys/ui": "*",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "next": "^16.2.4",
    "next-auth": "5.0.0-beta.31",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^10.2.1",
    "eslint-config-next": "^16.2.4",
    "postcss": "^8.5.0",
    "prisma": "^5.22.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
