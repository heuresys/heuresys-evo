# services/app — Next.js 16 + NextAuth v5

# Auth.js — MUST match services/api-gateway AUTH_SECRET so cookies are
# decodeable cross-service.
AUTH_SECRET=replace-me-with-32-byte-random-base64
AUTH_URL=http://localhost:3200
AUTH_TRUST_HOST=true

# Database — same host as api-gateway (Postgres bare-metal locale, porta 5432).
# NextAuth Credentials provider does the user lookup directly via Prisma.
DATABASE_URL=postgresql://heuresys:heuresys@localhost:5432/heuresys_platform?schema=public

# Where the api-gateway is reachable from server components (SSR fetches).
NEXT_PUBLIC_API_URL=http://localhost:8200

# Show the "Dev seed: evo.dev / admin123" hint on /login. Set to "1" only in
# local dev / staging — leave unset in production.
NEXT_PUBLIC_SHOW_DEV_HINT=

# Default tenant for SUPERUSER / SYSADMIN logins (no employee record).
# Replace with the tenant you want the dev SUPERUSER to scope into.
# fb1e866c-e90a-4e25-a146-f68d660a0be8 = EcoNova (26 employees)
# 0c54b84a-db6e-4da4-bc91-af5d480d524e = RTL Bank (158 employees)
DEFAULT_SUPERUSER_TENANT_ID=fb1e866c-e90a-4e25-a146-f68d660a0be8
