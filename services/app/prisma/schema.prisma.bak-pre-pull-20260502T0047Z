  employees                                                                                          employees?                            @relation("employeesToemployees", fields: [manager_id], references: [id], onUpdate: NoAction, map: "fk_employees_manager")
  other_employees                                                                                    employees[]                           @relation("employeesToemployees")
  users                                                                                              users[]

  @@unique([tenant_id, pernr], map: "employees_pernr_tenant_unique")
  @@index([auth_role], map: "idx_employees_auth_role")
  @@index([cost_center_id], map: "idx_employees_cost_center")
  @@index([department], map: "idx_employees_department")
  @@index([email], map: "idx_employees_email")
  @@index([employment_status], map: "idx_employees_employment_status")
  @@index([location_id], map: "idx_employees_location")
  @@index([manager_id], map: "idx_employees_manager_id")
  @@index([legacy_org_unit_code], map: "idx_employees_org_unit")
  @@index([org_unit_id], map: "idx_employees_org_unit_new")
  @@index([pernr], map: "idx_employees_pernr")
  @@index([profile_embedding], map: "idx_employees_profile_embedding")
  @@index([tenant_id], map: "idx_employees_tenant_id")
}

