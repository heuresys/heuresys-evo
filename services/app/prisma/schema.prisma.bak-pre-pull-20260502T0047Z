  pernr                                                                                              String?                               @db.VarChar(8)
  birth_date                                                                                         DateTime?                             @db.Date
  gender                                                                                             String?                               @db.VarChar(10)
  nationality                                                                                        String?                               @db.VarChar(50)
  salary                                                                                             Decimal?                              @db.Decimal(15, 2)
  currency                                                                                           String?                               @default("EUR") @db.VarChar(3)
  cost_center                                                                                        String?                               @db.VarChar(50)
  employee_group                                                                                     String?                               @db.VarChar(50)
  employee_subgroup                                                                                  String?                               @db.VarChar(50)
  position_id                                                                                        String?                               @db.VarChar(50)
  legacy_org_unit_code                                                                               String?                               @db.VarChar(50)
  cost_center_id                                                                                     String?                               @db.Uuid
  org_unit_id                                                                                        String?                               @db.Uuid
  middle_name                                                                                        String?                               @db.VarChar(100)
  birth_place                                                                                        String?                               @db.VarChar(100)
  marital_status                                                                                     String?                               @db.VarChar(20)
  address_street                                                                                     String?                               @db.VarChar(255)
  address_city                                                                                       String?                               @db.VarChar(100)
  address_postal_code                                                                                String?                               @db.VarChar(20)
  address_country                                                                                    String?                               @db.VarChar(3)
  address_region                                                                                     String?                               @db.VarChar(50)
  temp_address_street                                                                                String?                               @db.VarChar(255)
  temp_address_city                                                                                  String?                               @db.VarChar(100)
  temp_address_postal_code                                                                           String?                               @db.VarChar(20)
  temp_address_country                                                                               String?                               @db.VarChar(3)
  pay_scale_area                                                                                     String?                               @db.VarChar(50)
  pay_scale_type                                                                                     String?                               @db.VarChar(50)
  pay_scale_group                                                                                    String?                               @db.VarChar(50)
  pay_scale_level                                                                                    String?                               @db.VarChar(20)
  pay_periods_per_year                                                                               Int?                                  @default(12)
  work_schedule_percentage                                                                           Decimal?                              @default(100.00) @db.Decimal(5, 2)
  iban                                                                                               String?                               @db.VarChar(34)
  swift_bic                                                                                          String?                               @db.VarChar(11)
  bank_name                                                                                          String?                               @db.VarChar(100)
  bank_account_number                                                                                String?                               @db.VarChar(50)
  phone_mobile                                                                                       String?                               @db.VarChar(30)
  phone_work                                                                                         String?                               @db.VarChar(30)
  phone_home                                                                                         String?                               @db.VarChar(30)
  personal_email                                                                                     String?                               @db.VarChar(255)
  tax_id                                                                                             String?                               @db.VarChar(20)
  national_id                                                                                        String?                               @db.VarChar(30)
  national_id_expiry                                                                                 DateTime?                             @db.Date
  passport_number                                                                                    String?                               @db.VarChar(20)
  passport_expiry                                                                                    DateTime?                             @db.Date
  driver_license                                                                                     String?                               @db.VarChar(20)
  driver_license_expiry                                                                              DateTime?                             @db.Date
  probation_end_date                                                                                 DateTime?                             @db.Date
  seniority_date                                                                                     DateTime?                             @db.Date
  contract_end_date                                                                                  DateTime?                             @db.Date
  emergency_contact_name                                                                             String?                               @db.VarChar(100)
  emergency_contact_phone                                                                            String?                               @db.VarChar(30)
  emergency_contact_relationship                                                                     String?                               @db.VarChar(50)
  family_members                                                                                     Json?
  education_history                                                                                  Json?
