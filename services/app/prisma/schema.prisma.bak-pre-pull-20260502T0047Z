  termination_reason                                                                                 String?                               @db.VarChar(100)
  auth_username                                                                                      String?                               @db.VarChar(100)
  auth_password_hash                                                                                 String?                               @db.VarChar(255)
  auth_role                                                                                          String?                               @default("USER") @db.VarChar(50)
  auth_permissions                                                                                   String[]                              @default([])
  auth_last_login                                                                                    DateTime?                             @db.Timestamp(6)
  auth_username_candidate                                                                            String?                               @db.VarChar(200)
  location_id                                                                                        String?                               @db.Uuid
  profile_embedding                                                                                  Unsupported("vector")?
  embedding_text_hash                                                                                String?                               @db.VarChar(64)
  embedding_model                                                                                    String?                               @db.VarChar(100)
  embedding_generated_at                                                                             DateTime?                             @db.Timestamptz(6)
  deleted_at                                                                                         DateTime?                             @db.Timestamptz(6)
  enrichment_consent                                                                                 Boolean                               @default(false)
  enrichment_consent_at                                                                              DateTime?                             @db.Timestamptz(6)
  enrichment_consent_scope                                                                           String[]
