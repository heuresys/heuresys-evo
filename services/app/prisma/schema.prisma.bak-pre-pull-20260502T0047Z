  highest_education_institution                                                                      String?                               @db.VarChar(100)
  highest_education_field                                                                            String?                               @db.VarChar(100)
  highest_education_year                                                                             Int?
  company_code                                                                                       String?                               @db.VarChar(10)
  personnel_area                                                                                     String?                               @db.VarChar(10)
  personnel_subarea                                                                                  String?                               @db.VarChar(10)
  employment_status                                                                                  String?                               @default("active") @db.VarChar(20)
