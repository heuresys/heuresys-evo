# services/app — Next.js 16 frontend (port 3200)
PORT=3200
NODE_ENV=development
LOG_LEVEL=info

# Database — Postgres bare-metal + pgBouncer (transaction-mode) su VM port 6432.
# DATABASE_URL: connessione pooled, runtime queries. `pgbouncer=true` disabilita
# prepared statement caching client-side (incompatibile con transaction pooling).
# `connection_limit=10` evita saturazione del pool pgBouncer (default_pool_size=20).
# DIRECT_URL: bypass pgBouncer (porta 5432 diretta) per Prisma migrations + advisory locks.
# Dev locale via SSH tunnel: entrambe le URL puntano a 127.0.0.1:5432 (pgBouncer non in mezzo).
DATABASE_URL=postgresql://heuresys:heuresys@localhost:6432/heuresys_platform?schema=public&pgbouncer=true&connection_limit=10
DIRECT_URL=postgresql://heuresys:heuresys@localhost:5432/heuresys_platform?schema=public

# Auth.js v5 — shared secret with services/api-gateway
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-32-byte-random-base64
AUTH_TRUST_HOST=true

# NextAuth v4 cookie compatibility (cross-service JWT decode)
# Vedi services/api-gateway/src/lib/jwt-v4-decoder.ts
NEXTAUTH_SECRET=replace-me-with-32-byte-random-base64
NEXTAUTH_URL=http://localhost:3200

# Platform superuser fallback tenant (per utenti senza employee_id)
DEFAULT_SUPERUSER_TENANT_ID=00000000-0000-0000-0000-000000000000

# API gateway upstream (proxy fallback per endpoint non ancora migrati a route handlers Next.js)
API_GATEWAY_URL=http://localhost:8200
