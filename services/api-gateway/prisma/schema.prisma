model skill_classifications {
  id                          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  esco_skill_id               String          @unique(map: "uq_skill_classifications_esco") @db.Uuid
  primary_category            String          @db.VarChar(20)
  primary_category_confidence Decimal?        @db.Decimal(3, 2)
  cognitive_level             Int?
  cognitive_level_label       String?         @db.VarChar(30)
  social_dimension            String?         @db.VarChar(30)
  transferability             String          @default("transferable") @db.VarChar(20)
  transferability_score       Decimal?        @db.Decimal(3, 2)
  skill_cluster_id            String?         @db.Uuid
  classification_source       String?         @default("ai_assisted") @db.VarChar(50)
  classified_by               String?         @db.Uuid
  classified_at               DateTime?       @db.Timestamptz(6)
  needs_review                Boolean?        @default(false)
  review_notes                String?
  created_at                  DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at                  DateTime?       @default(now()) @db.Timestamptz(6)
  confidence_score            Decimal?        @default(0.0) @db.Decimal(5, 4)
  users                       users?          @relation(fields: [classified_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  esco_skills                 esco_skills     @relation(fields: [esco_skill_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  skill_clusters              skill_clusters? @relation(fields: [skill_cluster_id], references: [id], onUpdate: NoAction)

  @@index([primary_category], map: "idx_skill_class_category")
  @@index([skill_cluster_id], map: "idx_skill_class_cluster")
  @@index([cognitive_level], map: "idx_skill_class_cognitive")
  @@index([social_dimension], map: "idx_skill_class_social")
  @@index([classification_source], map: "idx_skill_class_source")
  @@index([transferability], map: "idx_skill_class_transfer")
  @@index([classified_by], map: "idx_skill_classifications_classified_by")
}

