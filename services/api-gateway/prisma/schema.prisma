model skill_clusters {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                  String                  @unique @db.VarChar(50)
  name_en               String                  @db.VarChar(200)
  name_it               String?                 @db.VarChar(200)
  description           String?
  parent_cluster_id     String?                 @db.Uuid
  cluster_level         Int?                    @default(1)
  career_path_codes     String[]
  industry_codes        String[]
  is_active             Boolean?                @default(true)
  sort_order            Int?                    @default(0)
  created_at            DateTime?               @default(now()) @db.Timestamptz(6)
  updated_at            DateTime?               @default(now()) @db.Timestamptz(6)
  deleted_at            DateTime?               @db.Timestamptz(6)
  skill_classifications skill_classifications[]
  skill_clusters        skill_clusters?         @relation("skill_clustersToskill_clusters", fields: [parent_cluster_id], references: [id], onUpdate: NoAction)
  other_skill_clusters  skill_clusters[]        @relation("skill_clustersToskill_clusters")

  @@index([career_path_codes], map: "idx_skill_clusters_career", type: Gin)
  @@index([industry_codes], map: "idx_skill_clusters_industry", type: Gin)
  @@index([cluster_level], map: "idx_skill_clusters_level")
  @@index([parent_cluster_id], map: "idx_skill_clusters_parent")
}

