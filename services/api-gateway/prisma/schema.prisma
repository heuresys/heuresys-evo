model employee_skills {
  id                                                           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id                                                    String       @db.Uuid
  employee_id                                                  String       @db.Uuid
  esco_skill_id                                                String?      @db.Uuid
  custom_skill_name                                            String?      @db.VarChar(255)
  proficiency_level                                            Int?
  proficiency_label                                            String?      @db.VarChar(50)
  years_experience                                             Decimal?     @db.Decimal(4, 1)
  is_primary                                                   Boolean?     @default(false)
  is_verified                                                  Boolean?     @default(false)
  verified_by                                                  String?      @db.Uuid
  verified_at                                                  DateTime?    @db.Timestamptz(6)
  source                                                       String?      @default("self_assessment") @db.VarChar(50)
  confidence_score                                             Decimal?     @db.Decimal(3, 2)
  last_used_at                                                 DateTime?    @db.Date
  notes                                                        String?
  created_at                                                   DateTime?    @default(now()) @db.Timestamptz(6)
  updated_at                                                   DateTime?    @default(now()) @db.Timestamptz(6)
  verified_by_employee_id                                      String?      @db.Uuid
  primary_category                                             String?      @db.VarChar(20)
  cognitive_level_achieved                                     Int?
  transferability_demonstrated                                 String?      @db.VarChar(20)
  employees_employee_skills_employee_idToemployees             employees    @relation("employee_skills_employee_idToemployees", fields: [employee_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  esco_skills                                                  esco_skills? @relation(fields: [esco_skill_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenants                                                      tenants      @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  employees_employee_skills_verified_by_employee_idToemployees employees?   @relation("employee_skills_verified_by_employee_idToemployees", fields: [verified_by_employee_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([employee_id], map: "idx_employee_skills_employee")
  @@index([esco_skill_id], map: "idx_employee_skills_esco")
  @@index([proficiency_level], map: "idx_employee_skills_proficiency")
  @@index([tenant_id], map: "idx_employee_skills_tenant")
  @@index([tenant_id, employee_id], map: "idx_employee_skills_tenant_employee")
  @@index([verified_by_employee_id], map: "idx_employee_skills_verified")
}

