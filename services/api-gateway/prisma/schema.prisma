model rbp_roles {
  id                     Int                    @id @default(autoincrement())
  code                   String                 @unique @db.VarChar(50)
  name                   String                 @db.VarChar(100)
  description            String?
  hierarchy_level        Int                    @unique(map: "rbp_roles_hierarchy_level_unique")
  is_system_role         Boolean                @default(true)
  is_assignable          Boolean                @default(true)
  inherits_from          String?                @db.VarChar(50)
  metadata               Json?                  @default("{}")
  created_at             DateTime               @default(now()) @db.Timestamptz(6)
  updated_at             DateTime               @default(now()) @db.Timestamptz(6)
  default_dashboard_code String?                @db.VarChar(50)
  description_it         String?
  description_en         String?
  rbp_roles              rbp_roles?             @relation("rbp_rolesTorbp_roles", fields: [inherits_from], references: [code], onDelete: NoAction, onUpdate: NoAction)
  other_rbp_roles        rbp_roles[]            @relation("rbp_rolesTorbp_roles")
}

