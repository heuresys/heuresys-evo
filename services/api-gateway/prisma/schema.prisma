model tenant_job_skills {
  id                         String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_job_id              String                       @db.Uuid
  source_skill_id            String?                      @db.Uuid
  skill_name_it              String                       @db.VarChar(255)
  skill_name_en              String?                      @db.VarChar(255)
  esco_skill_uri             String?                      @db.VarChar(255)
  esco_skill_code            String?                      @db.VarChar(50)
  required_level             Int?
  is_required                Boolean?                     @default(true)
  importance                 String?                      @db.VarChar(20)
  skill_category             String?                      @db.VarChar(50)
  is_custom                  Boolean?                     @default(false)
  created_at                 DateTime?                    @default(now()) @db.Timestamptz(6)
  employee_skill_assessments employee_skill_assessments[]
  tenant_jobs                tenant_jobs                  @relation(fields: [tenant_job_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([esco_skill_uri], map: "idx_tenant_skills_esco")
  @@index([tenant_job_id], map: "idx_tenant_skills_job")
  @@index([source_skill_id], map: "idx_tenant_skills_source")
}

