model employee_skill_profiles {
  id                                                       String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id                                                String                     @db.Uuid
  employee_id                                              String                     @db.Uuid
  skill_id                                                 String                     @db.Uuid
  knowledge_level                                          Int?                       @default(0) @db.SmallInt
  skill_level                                              Int?                       @default(0) @db.SmallInt
  ability_level                                            Int?                       @default(0) @db.SmallInt
  behavior_level                                           Int?                       @default(0) @db.SmallInt
  attitude_level                                           Int?                       @default(0) @db.SmallInt
  composite_score                                          Decimal?                   @default(0.00) @db.Decimal(4, 2)
  source                                                   skill_source_type          @default(self_declaration)
  source_description                                       String?
  acquired_date                                            DateTime?                  @db.Date
  last_demonstrated                                        DateTime?                  @db.Date
  evidence_type                                            String?                    @db.VarChar(50)
  evidence_id                                              String?                    @db.Uuid
  evidence_url                                             String?
  evidence_notes                                           String?
  verification_status                                      skill_verification_status? @default(pending)
  verified_by                                              String?                    @db.Uuid
  verified_at                                              DateTime?                  @db.Timestamptz(6)
  verification_notes                                       String?
  verification_expires_at                                  DateTime?                  @db.Date
  confidence_score                                         Decimal?                   @default(0.500) @db.Decimal(4, 3)
  is_primary                                               Boolean?                   @default(false)
  is_target                                                Boolean?                   @default(false)
  target_level                                             Int?                       @db.SmallInt
  created_at                                               DateTime?                  @default(now()) @db.Timestamptz(6)
  updated_at                                               DateTime?                  @default(now()) @db.Timestamptz(6)
  employees_employee_skill_profiles_employee_idToemployees employees                  @relation("employee_skill_profiles_employee_idToemployees", fields: [employee_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  esco_skills                                              esco_skills                @relation(fields: [skill_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenants                                                  tenants                    @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  employees_employee_skill_profiles_verified_byToemployees employees?                 @relation("employee_skill_profiles_verified_byToemployees", fields: [verified_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([tenant_id, employee_id, skill_id], map: "unique_employee_skill")
  @@index([verified_by], map: "idx_employee_skill_profiles_verified")
  @@index([composite_score(sort: Desc)], map: "idx_esp_composite")
  @@index([employee_id], map: "idx_esp_employee")
  @@index([skill_id], map: "idx_esp_skill")
  @@index([source], map: "idx_esp_source")
  @@index([tenant_id, employee_id], map: "idx_esp_tenant_employee")
  @@index([verification_status], map: "idx_esp_verification")
}

