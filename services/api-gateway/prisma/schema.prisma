  id                                         String                         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id                                  String                         @db.Uuid
  code                                       String                         @db.VarChar(30)
  name                                       String                         @db.VarChar(150)
  name_en                                    String?                        @db.VarChar(150)
  parent_id                                  String?                        @db.Uuid
  org_level                                  Int                            @default(1)
  org_type                                   String?                        @db.VarChar(30)
  legacy_department_id                       String?                        @db.Uuid
  default_location_id                        String?                        @db.Uuid
  manager_id                                 String?                        @db.Uuid
  deputy_manager_id                          String?                        @db.Uuid
  headcount_budget                           Int?
  is_active                                  Boolean?                       @default(true)
  valid_from                                 DateTime?                      @default(dbgenerated("CURRENT_DATE")) @db.Date
  valid_to                                   DateTime?                      @db.Date
  sort_order                                 Int?                           @default(0)
  created_at                                 DateTime?                      @default(now()) @db.Timestamptz(6)
  updated_at                                 DateTime?                      @default(now()) @db.Timestamptz(6)
  sap_objid                                  String?                        @db.VarChar(20)
  sap_short                                  String?                        @db.VarChar(20)
  sap_stext                                  String?                        @db.VarChar(100)
  sap_istat                                  String?                        @db.VarChar(5)
  sap_plvar                                  String?                        @default("01") @db.VarChar(5)
  sap_sync_date                              DateTime?                      @db.Timestamp(6)
  embedding                                  Unsupported("vector")?
  embedding_text_hash                        String?                        @db.VarChar(64)
  embedding_model                            String?                        @db.VarChar(100)
  embedding_generated_at                     DateTime?                      @db.Timestamptz(6)
  deleted_at                                 DateTime?                      @db.Timestamptz(6)
  description                                String?
  color                                      String?                        @db.VarChar(50)
  icon                                       String?                        @db.VarChar(100)
  sap_kostl                                  String?                        @db.VarChar(50)
  name_it                                    String?                        @db.VarChar(255)
  description_it                             String?
  description_en                             String?
  employees_employees_org_unit_idToorg_units employees[]                    @relation("employees_org_unit_idToorg_units")
  employees_org_units_manager_idToemployees  employees?                     @relation("org_units_manager_idToemployees", fields: [manager_id], references: [id], onUpdate: NoAction, map: "fk_ou_manager")
  tenants                                    tenants                        @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([legacy_department_id], map: "idx_org_units_department")
  @@index([embedding], map: "idx_org_units_embedding")
  @@index([manager_id], map: "idx_org_units_manager_id")
  @@index([tenant_id], map: "idx_org_units_tenant")
  @@index([org_type], map: "idx_org_units_type")
}

