/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model tenant_jobs {
  id                       String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id                String                     @db.Uuid
  source_template_id       String?                    @db.Uuid
  tenant_org_unit_id       String?                    @db.Uuid
  job_code                 String                     @db.VarChar(20)
  title_it                 String                     @db.VarChar(255)
  title_en                 String?                    @db.VarChar(255)
  description              String?
  summary                  String?
  org_level                Int?
  is_management            Boolean?                   @default(false)
  employment_type          String?                    @default("full_time") @db.VarChar(20)
  esco_occupation_uri      String?                    @db.VarChar(255)
  esco_occupation_code     String?                    @db.VarChar(20)
  salary_band_code         String?                    @db.VarChar(20)
  salary_min               Decimal?                   @db.Decimal(12, 2)
  salary_max               Decimal?                   @db.Decimal(12, 2)
  currency                 String?                    @default("EUR") @db.VarChar(3)
  budgeted_positions       Int?                       @default(1)
  filled_positions         Int?                       @default(0)
  custom_fields            Json?
  is_active                Boolean?                   @default(true)
  created_at               DateTime?                  @default(now()) @db.Timestamptz(6)
  updated_at               DateTime?                  @default(now()) @db.Timestamptz(6)
  deleted_at               DateTime?                  @db.Timestamptz(6)
  tenant_job_skills        tenant_job_skills[]
  tenants                  tenants                    @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([tenant_id, job_code], map: "uq_job_code_per_tenant")
  @@index([esco_occupation_code], map: "idx_tenant_jobs_esco")
  @@index([org_level], map: "idx_tenant_jobs_level")
  @@index([source_template_id], map: "idx_tenant_jobs_source")
  @@index([tenant_id], map: "idx_tenant_jobs_tenant")
  @@index([tenant_org_unit_id], map: "idx_tenant_jobs_unit")
}

