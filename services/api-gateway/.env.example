# API Gateway
PORT=8200
NODE_ENV=development
LOG_LEVEL=info

# Database — Postgres bare-metal locale (porta 5432). Su VM punta direttamente a localhost:5432.
# Sul PC: installare Postgres bare-metal via db/scripts/setup-local.sh + restore baseline.
DATABASE_URL=postgresql://heuresys:heuresys@localhost:5432/heuresys_platform?schema=public

# Auth.js — shared secret with services/app (when bootstrapped in A5).
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-32-byte-random-base64
AUTH_TRUST_HOST=true

# CORS — comma-separated allowed origins (services/app dev, services/marketing dev)
CORS_ORIGINS=http://localhost:3000,http://localhost:3100
