# API Gateway
PORT=8200
NODE_ENV=development
LOG_LEVEL=info

# Database — Postgres bare-metal locale (porta 5432). Su VM punta direttamente a localhost:5432.
# Sul PC: installare Postgres bare-metal via db/scripts/setup-local.sh + restore baseline.
DATABASE_URL=postgresql://heuresys:heuresys@localhost:5432/heuresys_platform?schema=public

# Auth.js — shared secret with services/app (when bootstrapped in A5).
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-32-byte-random-base64
AUTH_TRUST_HOST=true

# CORS — comma-separated allowed origins (services/app dev, services/marketing dev)
CORS_ORIGINS=http://localhost:3000,http://localhost:3100

# OpenAI advisor (Phase 14 Sprint 2.F · /ontology + advisor)
# Leave OPENAI_API_KEY empty to disable the advisor (route returns 503
# `advisor_unavailable` and the UI renders a "Setup required" panel).
# Cost cap is enforced server-side via Redis counter (incremented per completion);
# requests are rejected with 429 once the daily cap is reached.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_COST_CAP_USD_DAILY=5
OPENAI_TIMEOUT_MS=30000
