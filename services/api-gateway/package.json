{
  "name": "@heuresys/api-gateway",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Heuresys API Gateway â€” Express 5 + Prisma + Zod + Auth.js (Express adapter)",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "echo '@heuresys/api-gateway: lint via tsc only' && exit 0",
    "test": "vitest run",
    "prisma:pull": "prisma db pull --schema prisma/schema.prisma",
    "prisma:prune": "bash scripts/prune-prisma-schema.sh",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:refresh": "npm run prisma:pull && npm run prisma:prune && npm run prisma:generate",
    "clean": "rimraf dist node_modules/.cache",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@auth/express": "^0.12.2",
    "@heuresys/shared": "*",
    "@prisma/client": "^5.22.0",
    "@types/cookie-parser": "^1.4.10",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "25.8.0",
    "@types/supertest": "7.2.0",
    "@vitest/coverage-v8": "^4.1.0",
    "pino-pretty": "^13.1.3",
    "prisma": "5.22.0",
    "supertest": "7.2.2",
    "tsx": "4.22.1",
    "typescript": "6.0.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
