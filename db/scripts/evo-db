#!/bin/bash
# evo-db — wrapper user-friendly per il bucket-as-DB-git workflow.
#
# Usage:
#   evo-db pull [opts]      pull latest.dump from bucket + restore local DBMS
#   evo-db push [opts]      pg_dump + upload + promote latest.dump
#   evo-db status           read-only: confronto locale vs bucket
#   evo-db history          list dump objects in bucket (sorted by date)
#
# All subcommands accept --help for detailed usage.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

case "${1:-}" in
  pull)    shift; exec bash "$SCRIPT_DIR/db-pull.sh" "$@" ;;
  push)    shift; exec bash "$SCRIPT_DIR/db-push.sh" "$@" ;;
  status)  shift; exec bash "$SCRIPT_DIR/db-status.sh" "$@" ;;
  history) shift; exec bash "$SCRIPT_DIR/db-history.sh" "$@" ;;
  -h|--help|help|"")
    cat <<EOF
evo-db — bucket-as-DB-git workflow wrapper

Usage:
  evo-db pull [--object-name N] [--dry-run] [--no-safety]
                                    Pull latest.dump (or named object) and
                                    restore into local DBMS. Default: takes a
                                    safety dump of current state before restore.

  evo-db push [--no-promote] [--source-tag N] [--dry-run] [--force]
                                    Dump current DBMS + upload timestamped to
                                    bucket + promote as latest.dump. Soft-lock
                                    refuses push if bucket is newer than your
                                    last pull (use --force to override).

  evo-db status                     Read-only: shows local DBMS state vs bucket
                                    latest.dump + suggestion.

  evo-db history                    List all dump objects in bucket sorted by
                                    date (most recent first).

See db/README.md for full workflow details.
EOF
    exit 0 ;;
  *)
    echo "evo-db: unknown subcommand '$1'" >&2
    echo "Try 'evo-db --help'" >&2
    exit 2 ;;
esac
