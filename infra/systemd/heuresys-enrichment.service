[Unit]
Description=Heuresys evo — services/enrichment (BullMQ worker)
Documentation=https://github.com/heuresys/heuresys.com.evo/blob/main/docs/rtg-evo-log/2026-05-01-PH3-T9-T10-enrichment-scaffold.md
After=network-online.target redis.service postgresql.service
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/heuresys-evo/services/enrichment
EnvironmentFile=/home/ubuntu/heuresys-evo/services/enrichment/.env
Environment="NODE_ENV=production"
ExecStartPre=/usr/bin/npm run build --prefix /home/ubuntu/heuresys-evo/services/enrichment
ExecStart=/usr/bin/node /home/ubuntu/heuresys-evo/services/enrichment/dist/index.js
Restart=on-failure
RestartSec=10
KillMode=mixed
KillSignal=SIGTERM
TimeoutStopSec=60

# Hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/home/ubuntu/heuresys-evo
ProtectHome=read-only

# Logging
StandardOutput=append:/var/log/heuresys-evo/enrichment.log
StandardError=append:/var/log/heuresys-evo/enrichment.err

[Install]
WantedBy=multi-user.target
