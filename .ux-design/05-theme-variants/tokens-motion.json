{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Heuresys motion tokens — easings + durations + 5 canonical pattern presets. Theme-invariant (not affected by dark/light). SoT: .ux-design/04-motion-language/motion-final.md.",
  "$metadata": {
    "version": "1.0.0",
    "phase": "11",
    "anchor": "Phase 8 motion-final.md (L24)",
    "lastUpdate": "2026-05-07",
    "guideline": "Trustworthy 60% / Courage 40% — functional, never decorative. Max 600ms per UI element."
  },

  "easing": {
    "default": {
      "$type": "cubicBezier",
      "$value": [0.4, 0.0, 0.2, 1.0],
      "$description": "Active theme bezier (mu-architect default). Used in active-theme.css."
    },
    "out": {
      "$type": "cubicBezier",
      "$value": [0.16, 1.0, 0.3, 1.0],
      "$description": "Entry, reveal — primary UI default."
    },
    "inOut": {
      "$type": "cubicBezier",
      "$value": [0.45, 0.0, 0.55, 1.0],
      "$description": "Soft loops (breathing, glow pulse)."
    },
    "in": {
      "$type": "cubicBezier",
      "$value": [0.7, 0.0, 0.84, 0.0],
      "$description": "Exit, dismiss."
    },
    "spring": {
      "$type": "cubicBezier",
      "$value": [0.34, 1.56, 0.64, 1.0],
      "$description": "Use SPARINGLY — success confirm, achievement micro-celebration."
    }
  },

  "duration": {
    "instant": {
      "$type": "duration",
      "$value": "100ms",
      "$description": "Toggle, switch, theme change."
    },
    "fast": {
      "$type": "duration",
      "$value": "120ms",
      "$description": "Active-theme baseline fast (theme color transition)."
    },
    "hover": {
      "$type": "duration",
      "$value": "150ms",
      "$description": "Hover, focus state, ripple."
    },
    "base": {
      "$type": "duration",
      "$value": "200ms",
      "$description": "Active-theme baseline standard. Sparkline draw, gradient transitions."
    },
    "standard": {
      "$type": "duration",
      "$value": "300ms",
      "$description": "Reveal, slide, fade."
    },
    "slow": {
      "$type": "duration",
      "$value": "320ms",
      "$description": "Active-theme baseline slow."
    },
    "hero": {
      "$type": "duration",
      "$value": "600ms",
      "$description": "Hero entrance, loading skeleton complete. MAX for UI element."
    },
    "loopGlow": {
      "$type": "duration",
      "$value": "4s",
      "$description": "Wordmark glow breathing — very slow loop."
    }
  },

  "stagger": {
    "section": {
      "$type": "duration",
      "$value": "60ms",
      "$description": "Inter-child stagger for scroll reveals."
    }
  },

  "pattern": {
    "wordmarkGlow": {
      "$description": "Hero wordmark soft purple glow breathing. NEVER on dashboard chrome.",
      "duration": { "$type": "duration", "$value": "4s" },
      "easing": { "$type": "cubicBezier", "$value": [0.45, 0.0, 0.55, 1.0] },
      "iterations": "infinite",
      "from": "drop-shadow(0 0 60px rgba(168,85,247,0.20))",
      "to": "drop-shadow(0 0 60px rgba(168,85,247,0.35))"
    },
    "themeTransition": {
      "$description": "Theme dark↔light color tokens transition. NO layout/dimension transition.",
      "properties": ["background", "color", "border-color"],
      "duration": { "$type": "duration", "$value": "200ms" },
      "easing": { "$type": "cubicBezier", "$value": [0.16, 1.0, 0.3, 1.0] }
    },
    "kgTopologyHover": {
      "$description": "KG node hover: scale + edges focus/blur + tooltip.",
      "node": {
        "scaleFrom": 1.0,
        "scaleTo": 1.15,
        "duration": { "$type": "duration", "$value": "150ms" },
        "easing": { "$type": "cubicBezier", "$value": [0.16, 1.0, 0.3, 1.0] }
      },
      "edgesConnected": {
        "strokeOpacityFrom": 0.6,
        "strokeOpacityTo": 1.0,
        "duration": { "$type": "duration", "$value": "150ms" }
      },
      "edgesUnconnected": {
        "strokeOpacityFrom": 0.6,
        "strokeOpacityTo": 0.15,
        "duration": { "$type": "duration", "$value": "150ms" }
      },
      "tooltip": {
        "duration": { "$type": "duration", "$value": "200ms" },
        "easing": "fade-in"
      }
    },
    "sparklineDraw": {
      "$description": "KPI card sparkline left-to-right draw + count-up. Max 200ms (anti-slop).",
      "stroke": {
        "duration": { "$type": "duration", "$value": "200ms" },
        "easing": { "$type": "cubicBezier", "$value": [0.16, 1.0, 0.3, 1.0] },
        "technique": "stroke-dasharray-animation"
      },
      "countUp": {
        "duration": { "$type": "duration", "$value": "200ms" },
        "easing": { "$type": "cubicBezier", "$value": [0.16, 1.0, 0.3, 1.0] }
      }
    },
    "scrollReveal": {
      "$description": "Section reveal: opacity + translateY, stagger 60ms. ONE-TIME, no re-animate.",
      "opacityFrom": 0,
      "opacityTo": 1,
      "translateYFrom": "8px",
      "translateYTo": "0px",
      "duration": { "$type": "duration", "$value": "300ms" },
      "easing": { "$type": "cubicBezier", "$value": [0.16, 1.0, 0.3, 1.0] },
      "stagger": { "$type": "duration", "$value": "60ms" },
      "trigger": "first-viewport-entry-only"
    }
  },

  "auxiliary": {
    "buttonPress": {
      "scaleFrom": 1.0,
      "scaleVia": 0.97,
      "scaleTo": 1.0,
      "duration": { "$type": "duration", "$value": "100ms" },
      "easing": { "$type": "cubicBezier", "$value": [0.45, 0.0, 0.55, 1.0] }
    },
    "cardLift": {
      "translateY": "-2px",
      "borderColor": "{color.accent.default}",
      "duration": { "$type": "duration", "$value": "150ms" },
      "easing": { "$type": "cubicBezier", "$value": [0.16, 1.0, 0.3, 1.0] }
    },
    "skeletonShimmer": {
      "duration": { "$type": "duration", "$value": "1500ms" },
      "easing": "linear",
      "iterations": "infinite",
      "opacityRange": [0.3, 0.6]
    },
    "modalEnter": {
      "scaleFrom": 0.96,
      "scaleTo": 1.0,
      "opacityFrom": 0,
      "opacityTo": 1,
      "duration": { "$type": "duration", "$value": "200ms" },
      "easing": { "$type": "cubicBezier", "$value": [0.16, 1.0, 0.3, 1.0] }
    }
  },

  "antiPattern": {
    "$description": "Banished motion patterns (do NOT use).",
    "rejected": [
      "Animated status dots (blinking · pulsing · orbit)",
      "Spinning loaders > 16px (use skeleton instead)",
      "Bouncy/elastic easing on business UI",
      "Animation duration > 600ms for UI elements",
      "Auto-playing video / parallax overpowering",
      "Particle effects, confetti (rare exception: achievement micro-celebration)",
      "Re-animate scroll reveal on re-enter viewport (one-time only)"
    ]
  },

  "accessibility": {
    "prefersReducedMotion": {
      "$description": "Respect prefers-reduced-motion: reduce. Disable all motion or reduce to <0.01ms.",
      "css": "@media (prefers-reduced-motion: reduce) { *, *::before, *::after { animation-duration: 0.01ms !important; animation-iteration-count: 1 !important; transition-duration: 0.01ms !important; } }"
    }
  }
}
