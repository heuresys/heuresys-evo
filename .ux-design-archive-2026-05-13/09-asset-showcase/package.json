{
  "name": "@heuresys/asset-showcase",
  "version": "0.1.0",
  "private": true,
  "description": "Local-only asset catalog management webapp for Heuresys brand identity. Gitignored.",
  "type": "module",
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "db:push": "prisma db push --schema prisma/schema.prisma",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:studio": "prisma studio --schema prisma/schema.prisma",
    "bootstrap": "node bootstrap.js",
    "reset": "rm -f data.db && npm run db:push && npm run bootstrap"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "express": "5.2.1"
  },
  "devDependencies": {
    "prisma": "5.22.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
