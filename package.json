{
  "name": "heuresys-evo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Heuresys.com.evo — Organizational Intelligence & Workforce Orchestration platform",
  "license": "UNLICENSED",
  "author": "Heuresys <info@heuresys.com>",
  "workspaces": [
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:unit": "npm run test:unit --workspaces --if-present",
    "test:integration": "npm run test:integration --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspaces --if-present --parallel",
    "clean": "npm run clean --workspaces --if-present",
    "prepare": "husky",
    "db:reset:test": "DATABASE_URL_TEST=${DATABASE_URL_TEST:-postgresql://heuresys:heuresys@localhost:5433/heuresys_test} db/scripts/reset-test.sh",
    "test:e2e": "npm run test:e2e -w services/app --if-present",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "19.8.1",
    "@commitlint/config-conventional": "19.8.1",
    "husky": "9.1.7",
    "lint-staged": "15.5.2",
    "pg": "8.20.0",
    "prettier": "3.8.3",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "uuid": "^14.0.0",
    "exceljs": {
      "uuid": "^14.0.0"
    }
  }
}
